/* components/webgl/Loader.module.pcss */

.canvasElement {
  position: fixed; /* Covers the entire viewport */
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none; /* Loader overlay shouldn't block interactions */
  z-index: 99; /* High z-index, but potentially below DOM loader elements */
  opacity: 1; /* Base opacity */
  /* Transitions are handled by the component's GSAP animation */
}
