/* components/MouseCursor.module.pcss */

.mouse {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 49;
  pointer-events: none;
}

.mouse-down {
  cursor: none !important;
}

.mouse_el {
  position: absolute;
  left: 2rem;
  top: -0.8rem;
  overflow: hidden;
}

.mouse_el .Awrite {
  white-space: nowrap;
}

.mouse_el .Awrite-w {
  --dark: #f8f6f2;
  --light: #000;
}

.hoverElement {
  position: absolute;
  left: 15px; /* Adjust positioning based on original */
  top: -8px; /* Adjust positioning */
  overflow: hidden; /* Needed for width animation */
  white-space: nowrap;
  background-color: transparent; /* Or style as needed */
  width: 0; /* Controlled by GSAP */
}

.inverted {
  /* Styles matching original .Awrite-inv */
  color: var(--light);
  background: var(--dark);
}

/* Hide cursor on touch devices if desired */
@media (hover: none) {
  .mouse {
    display: none;
  }
}