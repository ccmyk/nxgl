/* components/layout/MouseCursor.module.pcss */

.mouse {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 49;
  pointer-events: none;
}

.mouse-down {
  cursor: none !important;
}

.hoverElement {
  position: absolute;
  left: 2rem;
  top: -0.8rem;
  overflow: hidden;
  white-space: nowrap;
}

.hoverContent {
  display: inline-block;
  white-space: nowrap;
  --light: #000;
  --dark: #f8f6f2;
  color: var(--dark);
}

/* Optional inverted theme styles can be toggled in component logic */
.hoverContent.Awrite-inv {
  color: var(--light);
  background-color: var(--dark);
}

@media (hover: none) {
  .mouse {
    display: none;
  }
}
