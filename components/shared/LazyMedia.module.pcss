/* components/shared/LazyMedia.module.pcss */
.lazyMediaWrapper {
  position: relative;
  overflow: hidden;
  background-color: #e0e0e0;
  width: 100%;
}

.mediaContent {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.5s ease-in-out;
}

.lazyMediaWrapper.loaded .mediaContent {
  opacity: 1;
}

.media {
  width: 100%;
  height: auto;
  overflow: hidden;
}

